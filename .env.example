SUMINAR_DATA_DIR=data
SUMINAR_PORT=4317
SUMINAR_PYTHON=python
SUMINAR_OPENAI_MODEL=gpt-5-mini
# minimal | low | medium | high — hosted scholarly deployments run medium.
SUMINAR_OPENAI_REASONING_EFFORT=minimal
OPENAI_API_KEY=
MISTRAL_API_KEY=
# Development only: allow http://localhost federation fixtures.
SUMINAR_ALLOW_PRIVATE_ORIGINS=0

# Hosted mode (Phase 2). Secrets live in Vercel env / local .env, never committed.
SUPABASE_URL=https://ncrlodjkdwfpojvtjyby.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# The deployed extraction function URL + shared secret. When SUMINAR_EXTRACT_URL
# is set, hosted ingestion calls the Vercel PyMuPDF function; when unset it
# falls back to the local pypdf pipeline (dev/self-host).
SUMINAR_EXTRACT_URL=
SUMINAR_EXTRACT_SECRET=
# Public repo URL surfaced at /version once the kernel is published.
SUMINAR_SOURCE_URL=

# Live test credentials (run the env-gated hosted.*.live tests). Local only.
# The anon key additionally enables the RLS-as-authenticated trust tests.
SUMINAR_TEST_SUPABASE_URL=
SUMINAR_TEST_SUPABASE_SERVICE_ROLE_KEY=
SUMINAR_TEST_SUPABASE_ANON_KEY=

# Request-frequency limits (fail-open; defaults in src/hosted/ratelimit.ts).
# SUMINAR_RATE_MCP_PER_MINUTE=120
# SUMINAR_RATE_UPLOADS_PER_HOUR=20
# SUMINAR_RATE_EXPORTS_PER_HOUR=6
# SUMINAR_RATE_WAITLIST_PER_HOUR=5
